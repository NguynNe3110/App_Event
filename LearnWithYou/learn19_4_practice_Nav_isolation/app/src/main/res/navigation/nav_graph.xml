<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">
    <fragment
        android:id="@+id/homeFragment"
        android:name="com.uzuu.learn19_4_practice_nav_isolation.feature.main.HomeFragment"
        android:label="Home">
        <action
            android:id="@+id/action_home_to_list"
            app:destination="@+id/listFragment"/>
    </fragment>


    <fragment
        android:id="@+id/listFragment"
        android:name="com.uzuu.learn19_4_practice_nav_isolation.feature.listview.ListFragment"
        android:label="List">
        <action
            android:id="@+id/action_list_to_detail"
            app:destination="@+id/detailFragment"/>
    </fragment>

    <fragment
        android:id="@+id/detailFragment"
        android:name="com.uzuu.learn19_4_practice_nav_isolation.feature.detail.DetailFragment"
        android:label="Detail">
        <argument
            android:name="productId"
            app:argType="integer"/>
    </fragment>
</navigation>