<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.uzuu.learn19_5_bottomnav_basic.feature.home.HomeFragment"
        android:label="Home" >

    </fragment>

    <fragment
        android:id="@+id/searchFragment"
        android:name="com.uzuu.learn19_5_bottomnav_basic.feature.search.SearchFragment"
        android:label="Search">
        <action
            android:id="@+id/action_search_to_detail"
            app:destination="@+id/profileFragment"/>
    </fragment>

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.uzuu.learn19_5_bottomnav_basic.feature.profile.ProfileFragment"
        android:label="Profile">
        <argument
            android:name="productId"
            app:argType="integer"/>
    </fragment>

    <fragment
        android:id="@+id/countFragment"
        android:name="com.uzuu.learn19_5_bottomnav_basic.feature.count.CountFragment"
        android:label="Count" />

    <fragment
        android:id="@+id/bookFragment"
        android:name="com.uzuu.learn19_5_bottomnav_basic.feature.book.BookFragment"
        android:label="Book" >
        <action
            android:id="@+id/action_register_to_detailRegister"
            app:destination="@+id/detailRegisterFragment"/>
    </fragment>

    <fragment
        android:id="@+id/registerFragment"
        android:name="com.uzuu.learn19_5_bottomnav_basic.feature.book.registedCalender.RegistedFragment"
        android:label="Register" >

    </fragment>

    <fragment
        android:id="@+id/detailRegisterFragment"
        android:name="com.uzuu.learn19_5_bottomnav_basic.feature.book.registedCalender.detailRegister.DetailRegisterFragment"
        android:label="Book" >
        <argument
            android:name="timeId"
            app:argType="integer"/>
    </fragment>
</navigation>