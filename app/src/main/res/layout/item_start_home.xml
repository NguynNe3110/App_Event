<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    app:contentPadding="12dp"
    app:strokeColor="@color/blue_border_8"
    android:backgroundTint="@color/blue_surface_9"
    android:layout_marginBottom="16dp"
    app:cardElevation="6dp">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="4dp"
        android:orientation="vertical">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:weightSum="2"
            android:orientation="horizontal">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1.3">
                <TextView
                    android:id="@+id/txt_nameEvent_start"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/blue_accent_600"
                    android:text="Vở hài kịch tên trộm gặp tên cướp"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:textSize="20sp"
                    android:textStyle="bold"/>
            </LinearLayout>


            <TextView
                android:id="@+id/txt_address_start"
                android:layout_width="0dp"
                android:layout_weight="0.7"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:gravity="end"
                android:layout_gravity="end"
                android:text="Hà Nội"/>
        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:weightSum="2"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:layout_gravity="center"
            android:orientation="horizontal">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1.15">
                <TextView
                    android:id="@+id/txt_price_start"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#FF0000"
                    android:text="40.000đ"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:textSize="22sp"
                    android:textStyle="bold"/>
            </LinearLayout>
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="0.85">
                <TextView
                    android:id="@+id/txt_status_start"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="● Đang bán vé"
                    android:layout_gravity="end"
                    android:textSize="16dp"
                    android:textColor="#B851169E"
                    android:gravity="end"/>
            </LinearLayout>
        </LinearLayout>
        <TextView
            android:id="@+id/txt_ticketQuantity_start"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Số vé:"
            android:textSize="14sp"/>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>